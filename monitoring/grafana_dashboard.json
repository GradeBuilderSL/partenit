{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Partenit Safety Guard — real-time admissibility and trust metrics",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Decisions / sec",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "orange", "value": 100}]}}},
      "targets": [
        {
          "expr": "rate(partenit_guard_decisions_total[1m])",
          "legendFormat": "decisions/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Block Rate",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.05}, {"color": "red", "value": 0.2}]}
        }
      },
      "targets": [
        {
          "expr": "rate(partenit_guard_decisions_total{allowed=\"false\"}[5m]) / rate(partenit_guard_decisions_total[5m])",
          "legendFormat": "block rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p99 Guard Latency",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(partenit_guard_latency_ms_bucket[5m]))",
          "legendFormat": "p99 ms",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Min Sensor Trust",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "orange", "value": 0.5}, {"color": "green", "value": 0.8}]}
        }
      },
      "targets": [
        {
          "expr": "min(partenit_sensor_trust_level)",
          "legendFormat": "min trust",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Guard Decisions",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "options": {"tooltip": {"mode": "multi"}},
      "fieldConfig": {
        "defaults": {"custom": {"lineWidth": 2}},
        "overrides": [{"matcher": {"id": "byName", "options": "blocked"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]
      },
      "targets": [
        {"expr": "rate(partenit_guard_decisions_total{allowed=\"true\"}[1m])", "legendFormat": "allowed", "refId": "A"},
        {"expr": "rate(partenit_guard_decisions_total{allowed=\"false\"}[1m])", "legendFormat": "blocked", "refId": "B"},
        {"expr": "rate(partenit_guard_decisions_total{modified=\"true\"}[1m])", "legendFormat": "clamped", "refId": "C"}
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Risk Score",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "options": {"tooltip": {"mode": "multi"}},
      "fieldConfig": {
        "defaults": {"min": 0, "max": 1, "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "targets": [
        {"expr": "partenit_risk_score", "legendFormat": "risk score", "refId": "A"},
        {"expr": "histogram_quantile(0.99, rate(partenit_guard_latency_ms_bucket[5m])) / 1000", "legendFormat": "latency p99 (s)", "refId": "B"}
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Sensor Trust Levels",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "options": {"tooltip": {"mode": "multi"}},
      "fieldConfig": {
        "defaults": {"min": 0, "max": 1, "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "targets": [
        {"expr": "partenit_sensor_trust_level", "legendFormat": "{{sensor_id}}", "refId": "A"}
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Guard Latency Percentiles",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "options": {"tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineWidth": 2}}},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(partenit_guard_latency_ms_bucket[5m]))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, rate(partenit_guard_latency_ms_bucket[5m]))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, rate(partenit_guard_latency_ms_bucket[5m]))", "legendFormat": "p99", "refId": "C"}
      ]
    },
    {
      "id": 30,
      "type": "table",
      "title": "Top Fired Policies (last 5 min)",
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 19},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "options": {"showHeader": true},
      "transformations": [{"id": "sortBy", "options": {"fields": [{"desc": true, "displayName": "Value"}]}}],
      "targets": [
        {"expr": "topk(10, increase(partenit_policy_fires_total[5m]))", "legendFormat": "{{rule_id}}", "refId": "A", "instant": true}
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["partenit", "safety", "robotics"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Partenit Safety Guard",
  "uid": "partenit-guard-v1",
  "version": 1
}
